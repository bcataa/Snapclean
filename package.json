{
  "name": "cleanshot-web",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "clean": "rm -rf .next out",
    "build": "next build",
    "build:web": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"electron .\"",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "fabric": "^7.2.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.snapclean.app",
    "productName": "SnapClean",
    "files": [
      "electron/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": false
      }
    },
    "dmg": {
      "artifactName": "SnapClean-mac.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "${env.GH_OWNER}",
        "repo": "${env.GH_REPO}"
      }
    ]
  }
}
